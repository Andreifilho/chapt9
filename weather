#include <iostream>
using namespace std;

class WeatherReport
{
private:
    float temp[7][2];

public:
    void input_temperature()
    {
        for(int i = 0; i < 7; i++)
        {
            cout << "Day " << i+1 << " morning temp: ";
            cin >> temp[i][0];

            cout << "Day " << i+1 << " evening temp: ";
            cin >> temp[i][1];
        }
    }

    void display_temperature()
    {
        for(int i = 0; i < 7; i++)
        {
            cout << "Day " << i+1 << ": "
                 << temp[i][0] << " "
                 << temp[i][1] << endl;
        }
    }

    void display_hottest_day()
    {
        float max_avg = -1000;
        int hottest_day = 0;

        for(int i = 0; i < 7; i++)
        {
            float avg = (temp[i][0] + temp[i][1]) / 2;

            if(avg > max_avg)
            {
                max_avg = avg;
                hottest_day = i + 1;
            }
        }

        cout << "Hottest Day: Day " << hottest_day << endl;
    }
};

int main()
{
    WeatherReport w;

    w.input_temperature();
    w.display_temperature();
    w.display_hottest_day();
}
