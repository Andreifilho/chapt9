#include <iostream>
using namespace std;

enum SlotStatus { EMPTY, OCCUPIED, RESERVED };

class WarehouseSystem
{
private:
    int shelf_units[4][5];
    SlotStatus slot_status[4][5];
    int shipped_units_per_day[7];
    int total_units_in_warehouse;

public:
    void initialize_system()
    {
        total_units_in_warehouse = 0;

        for(int i = 0; i < 4; i++)
        {
            for(int j = 0; j < 5; j++)
            {
                shelf_units[i][j] = 0;
                slot_status[i][j] = EMPTY;
            }
        }

        for(int i = 0; i < 7; i++)
            shipped_units_per_day[i] = 0;
    }

    void display_shelf_map()
    {
        for(int i = 0; i < 4; i++)
        {
            for(int j = 0; j < 5; j++)
            {
                if(slot_status[i][j] == EMPTY) cout << "E ";
                else if(slot_status[i][j] == OCCUPIED) cout << "O ";
                else cout << "R ";
            }
            cout << endl;
        }
    }

    void reserve_slot(int row, int col)
    {
        if(slot_status[row][col] == EMPTY)
        {
            slot_status[row][col] = RESERVED;
            cout << "Slot reserved successfully!" << endl;
        }
        else
            cout << "Cannot reserve. Slot is not empty." << endl;
    }

    void add_stock(int row, int col, int units)
    {
        if(units > 0 && (slot_status[row][col] == EMPTY || slot_status[row][col] == RESERVED))
        {
            shelf_units[row][col] = units;
            slot_status[row][col] = OCCUPIED;
            total_units_in_warehouse += units;
        }
    }

    void ship_stock(int row, int col, int units, int day_number)
    {
        if(slot_status[row][col] == OCCUPIED && units <= shelf_units[row][col])
        {
            shelf_units[row][col] -= units;
            total_units_in_warehouse -= units;

            shipped_units_per_day[day_number - 1] += units;

            if(shelf_units[row][col] == 0)
                slot_status[row][col] = EMPTY;
        }
    }

    void display_weekly_shipping_report()
    {
        int total = 0;

        for(int i = 0; i < 7; i++)
        {
            cout << "Day " << i+1 << ": " << shipped_units_per_day[i] << endl;
            total += shipped_units_per_day[i];
        }

        cout << "Total shipped: " << total << endl;
    }

    void find_best_shipping_day()
    {
        int max_units = -1;
        int best_day = 0;

        for(int i = 0; i < 7; i++)
        {
            if(shipped_units_per_day[i] > max_units)
            {
                max_units = shipped_units_per_day[i];
                best_day = i + 1;
            }
        }

        cout << "Best shipping day: Day " << best_day << endl;
    }
};

int main()
{
    WarehouseSystem w;

    w.initialize_system();
    w.reserve_slot(1,2);
    w.add_stock(1,2,50);
    w.ship_stock(1,2,20,3);

    w.display_shelf_map();
    w.display_weekly_shipping_report();
    w.find_best_shipping_day();
}
